# ==============================================================================
# TERRAFORM GIT IGNORE FILE
# ==============================================================================
# Prevents sensitive and temporary files from being committed to Git
# ==============================================================================

# ==============================================================================
# STATE FILES
# ==============================================================================
# Contains sensitive information about your infrastructure
# NEVER commit state files to Git!

terraform.tfstate      # Current state
terraform.tfstate.*    # State backups
*.tfstate
*.tfstate.backup

# ==============================================================================
# LOCK FILES
# ==============================================================================
# Generated by Terraform, not needed in Git

.terraform.lock.hcl

# ==============================================================================
# TERRAFORM CONFIGURATION FILES
# ==============================================================================
# Contains secrets and credentials

terraform.tfvars       # Your variable values (passwords, IDs, etc.)
terraform.tfvars.json  # JSON version
*.tfvars              # Any .tfvars files
*.tfvars.json

# ==============================================================================
# TEMPORARY TERRAFORM FILES
# ==============================================================================

.terraform/           # Downloaded modules and providers
.terraform.lock       # Lock file
crash.log             # Crash logs

# ==============================================================================
# KUBECONFIG FILES
# ==============================================================================
# Contains Kubernetes credentials

kubeconfig
kubeconfig.yaml
kubeconfig.yml
.kubeconfig

# ==============================================================================
# AZURE AUTHENTICATION FILES
# ==============================================================================

.azure/              # Azure CLI cache
.azure/tokens.json   # Cached tokens
az.log              # Azure CLI logs

# ==============================================================================
# IDE/EDITOR FILES
# ==============================================================================

.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.tfplan

# ==============================================================================
# ENVIRONMENT FILES
# ==============================================================================

.env
.env.local
.env.*.local

# ==============================================================================
# LOGS
# ==============================================================================

*.log
logs/

# ==============================================================================
# BUILD ARTIFACTS
# ==============================================================================

dist/
build/
*.zip

# ==============================================================================
# PYTHON ARTIFACTS
# ==============================================================================

__pycache__/
*.py[cod]
*.egg-info/

# ==============================================================================
# NODE ARTIFACTS
# ==============================================================================

node_modules/
package-lock.json
yarn.lock

# ==============================================================================
# SENSITIVE PATTERNS
# ==============================================================================
# Files that might contain secrets

*secret*
*credential*
*password*
*token*
*private*
*key*
*.pem
*.key

# ==============================================================================
# EXCEPTIONS
# ==============================================================================
# Files we DO want to commit

!.gitignore
!.github/
!.gitkeep
!README.md
!*.example